# FluGuard AI Frontend — Environment Variables
# For local development: copy to .env and fill in values.
# For Vercel deployment: set these in Project Settings → Environment Variables.

# ── Required ──────────────────────────────────────────────────────────────────
# Railway backend URL (no trailing slash)
# Example: https://fluguard-backend.up.railway.app
VITE_BACKEND_URL=https://your-railway-backend-url.up.railway.app
