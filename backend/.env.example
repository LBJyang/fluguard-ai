# FluGuard AI Backend — Environment Variables
# Copy this file to .env for local development (never commit .env)

# ── Required ──────────────────────────────────────────────────────────────────
# Google AI Studio API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the Gemma 4 model (default: gemma-4-27b-it)
# Options: gemma-4-27b-it, gemma-4-9b-it, gemma-3-27b-it
# GEMMA_MODEL=gemma-4-27b-it

# Port (Railway sets this automatically; override only for local dev)
# PORT=8000
